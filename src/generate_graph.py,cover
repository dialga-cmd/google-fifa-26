>         pos_v = (G.nodes[v]['x'], G.nodes[v]['y'])
>         dist = ((pos_u[0] - pos_v[0])**2 + (pos_u[1] - pos_v[1])**2)**0.5
>         G.add_edge(u, v, base_distance=dist)
  
